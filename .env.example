# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored — never commit keys or passwords.
#
# cp .env.example .env.local

# Database
# Local: postgresql://farmeriq:farmeriq@localhost:5432/farmeriq
# Supabase (testing): Project Settings → Database → URI, append ?sslmode=require
# Use direct connection (5432) for migrations; pooler (6543) for Vercel serverless API
DATABASE_URL=postgresql://farmeriq:farmeriq@localhost:5432/farmeriq

# Development only — skip login and browse the UI (set false before production)
SKIP_AUTH=true
VITE_SKIP_AUTH=true

# API
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=14d

# Web (Vite dev server proxies to API locally; on Vercel use rewrites or set to API URL)
VITE_API_URL=http://localhost:3001

# Vercel / Supabase testing (set in Vercel dashboard, not always needed locally)
# WEB_ORIGIN=https://your-app.vercel.app
